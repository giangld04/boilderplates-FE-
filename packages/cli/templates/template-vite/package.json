    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/node": "^22",
    "typescript": "^5.9.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "vite": "^8.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.12",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/router-devtools": "^1.166.12",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5.2.0",
